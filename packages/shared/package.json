{
  "name": "@kilo/shared",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/index.ts",
    "./schemas": "./src/schemas/index.ts",
    "./lib": "./src/lib/index.ts",
    "./db": "./src/db/kysely/client.ts",
    "./db/types": "./src/db/types.ts"
  },
  "scripts": {
    "codegen": "kysely-codegen --out-file ./src/db/types.ts",
    "migrate:create": "../../scripts/migrate/create.sh",
    "migrate:up": "../../scripts/migrate/up.sh",
    "migrate:down": "../../scripts/migrate/down.sh",
    "migrate:version": "../../scripts/migrate/version.sh",
    "migrate:force": "../../scripts/migrate/force.sh"
  },
  "dependencies": {
    "zod": "^4.3.5",
    "kysely": "^0.28.9",
    "pg": "^8.16.3",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/pg": "^8.16.0",
    "kysely-codegen": "^0.19.0",
    "typescript": "^5"
  }
}
