{
  "name": "kilo-tracker",
  "private": true,
  "scripts": {
    "start": "pnpm --filter @kilo/web start",
    "api": "pnpm --filter @kilo/web dev",
    "mobile": "cd mobile && pnpm --filter @kilo/mobile start",
    "build:web": "pnpm --filter @kilo/web build",
    "test:web:unit": "pnpm --filter @kilo/web test:unit",
    "test:web:e2e": "pnpm --filter @kilo/web test:e2e",
    "test:mobile": "pnpm --filter @kilo/mobile test",
    "lint": "pnpm -r lint",
    "migrate:create": "pnpm --filter @kilo/shared migrate:create",
    "migrate:up": "pnpm --filter @kilo/shared migrate:up",
    "migrate:down": "pnpm --filter @kilo/shared migrate:down",
    "migrate:version": "pnpm --filter @kilo/shared migrate:version",
    "migrate:force": "pnpm --filter @kilo/shared migrate:force",
    "codegen": "pnpm --filter @kilo/shared codegen"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
